{
  "info": {
    "name": "School Management API",
    "description": "API collection for School Management System including adding schools and listing them by proximity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Greenwood High\",\n    \"address\": \"123 Education Lane\",\n    \"latitude\": 28.704059,\n    \"longitude\": 77.102490\n}"
        },
        "url": {
          "raw": "http://localhost:3000/addSchool",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "addSchool"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List Schools by Proximity",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/listSchools?latitude=28.7041&longitude=77.1025",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "28.7041"
            },
            {
              "key": "longitude",
              "value": "77.1025"
            }
          ]
        }
      },
      "response": []
    }
  ]
}
